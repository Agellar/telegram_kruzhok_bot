# ─── Бот (обязательно) ────────────────────────────────────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...
# @username канала или числовой ID (-100xxxxxxxxxx). Бот должен быть админом канала.
CHANNEL_ID=@your_channel

# ─── Базовые настройки ────────────────────────────────────────────────────────
TEMP_DIR=/tmp/videobot
MAX_PARALLEL=4
# Лимит размера входного файла.
# - Облачный Bot API: максимум 20 МБ (Telegram-ограничение)
# - Локальный Bot API: до 2000 МБ
MAX_FILE_MB=20
# Минимальный интервал между запросами одного пользователя, сек
USER_COOLDOWN=5

# Путь к файлу статистики внутри контейнера (том botdata). Менять не нужно.
STATS_DB=/data/stats.db

# ─── Админка ──────────────────────────────────────────────────────────────────
# Домен для веб-панели (A-запись должна указывать на этот сервер).
DOMAIN=clup.untrace.cc
# Логин/пароль для входа в админку (HTTP Basic Auth).
ADMIN_USER=admin
ADMIN_PASS=change-me

# ─── Локальный Bot API сервер (опционально) ──────────────────────────────────
# Если задан — снимает лимит 20 МБ. Подробности — в README.md.
# TELEGRAM_API_BASE=http://telegram-bot-api:8081
# Нужны только для docker-compose, чтобы поднять локальный сервер.
# Получи их на https://my.telegram.org → API development tools.
# TELEGRAM_API_ID=1234567
# TELEGRAM_API_HASH=abcdef0123456789abcdef0123456789
