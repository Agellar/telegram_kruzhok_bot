# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# @username канала или числовой ID (-100xxxxxxxxxx). Бот должен быть админом канала.
CHANNEL_ID=@your_channel

# Каталог для временных файлов
TEMP_DIR=/tmp/videobot

# Сколько параллельных ffmpeg-конвертаций разрешено
MAX_PARALLEL=2

# Лимит размера входного файла (Bot API без локального сервера — максимум 20 МБ)
MAX_FILE_MB=20

# Минимальный интервал между запросами одного пользователя, сек
USER_COOLDOWN=5
